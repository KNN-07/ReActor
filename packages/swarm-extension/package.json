{
  "type": "module",
  "name": "@reactor/swarm-extension",
	"private": true,
  "version": "0.1.0",
  "description": "Swarm orchestration extension for reactor",
  "homepage": "https://reactor.sh",
  "author": "Derek Rynd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KNN-07/ReActor.git",
    "directory": "packages/swarm-extension"
  },
  "bugs": {
    "url": "https://github.com/KNN-07/ReActor/issues"
  },
  "keywords": [
    "swarm",
    "orchestration",
    "agent",
    "extension"
  ],
  "bin": {
    "reactor-swarm": "src/cli.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@reactor/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "@reactor/coding-agent": "workspace:*"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "reactor": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ]
}
