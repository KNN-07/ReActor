{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReActor Desktop",
  "version": "0.1.0",
  "identifier": "id.norman.reactor.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    },
    "windows": [{ "label": "main", "title": "ReActor Desktop", "width": 1440, "height": 900, "minWidth": 960, "minHeight": 640 }]
  },
  "bundle": { "active": true, "targets": "all", "externalBin": ["binaries/reactor-sidecar"] }
}
